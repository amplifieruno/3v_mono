# Production environment variables for ITAP

# PostgreSQL Database
POSTGRES_DB=itap_prod
POSTGRES_USER=itap_user
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# Redis Cache
REDIS_PASSWORD=your_secure_redis_password_here

# MinIO Object Storage (S3-compatible)
MINIO_ROOT_USER=your_minio_access_key_here
MINIO_ROOT_PASSWORD=your_secure_minio_secret_key_here
MINIO_ACCESS_KEY=your_minio_access_key_here
MINIO_SECRET_KEY=your_secure_minio_secret_key_here
MINIO_ENDPOINT=minio:9000

# Backend API
DATABASE_URL=postgresql://itap_user:your_secure_postgres_password_here@postgres:5432/itap_prod
REDIS_URL=redis://:your_secure_redis_password_here@redis:6379
JWT_SECRET=your_secure_jwt_secret_here
BACKEND_PORT=3001

# Frontend
VITE_API_URL=http://backend:3001
VITE_WS_URL=ws://backend:3001

# InsightFace API
INSIGHTFACE_API_URL=http://insightface:18080
INSIGHTFACE_API_KEY=your_insightface_api_key_here

# Node Environment
NODE_ENV=production