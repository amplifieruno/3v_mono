{
  "name": "shared",
  "version": "1.0.0",
  "description": "Shared types and utilities for ITAP monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "zod": "catalog:zod"
  },
  "devDependencies": {
    "typescript": "catalog:typescript",
    "eslint": "catalog:eslint",
    "@typescript-eslint/eslint-plugin": "catalog:@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser": "catalog:@typescript-eslint/parser"
  }
}