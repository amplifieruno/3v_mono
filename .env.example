# Environment Configuration Example
# Copy this file to .env and update the values

# Node Environment
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://itap_user:itap_password@localhost:5432/itap_dev
POSTGRES_PASSWORD=itap_password

# Redis Configuration
REDIS_URL=redis://:redis_password@localhost:6379
REDIS_PASSWORD=redis_password

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=itap-storage

# CompreFace Configuration
COMPREFACE_API_URL=http://localhost:8081
COMPREFACE_API_KEY=your_api_key_here
COMPREFACE_DB_PASSWORD=compreface_password

# JWT Configuration
JWT_SECRET=your_very_long_random_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Application Configuration
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
FACE_SERVICE_URL=http://localhost:3002

# File Upload Configuration
MAX_FILE_SIZE=10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=combined

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Development Configuration
HOT_RELOAD=true
ENABLE_CORS=true
ENABLE_LOGGING=true